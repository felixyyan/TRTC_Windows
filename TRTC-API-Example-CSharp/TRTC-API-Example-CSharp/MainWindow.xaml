<Window x:Class="TRTCWPFDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TRTCWPFDemo"
        mc:Ignorable="d"
        Title="TRTC WPF Demo" Height="768" Width="1280"
        Closing="Window_Closing"
        Background="#F0F2F5" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- 通用按钮样式 -->
        <Style x:Key="NormalButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#006EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3385FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005CE6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 危险操作按钮样式 -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource NormalButtonStyle}">
            <Setter Property="Background" Value="#FF4D4F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF7875"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D9363E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 视频控制图标按钮样式 -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#80000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B3000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E6000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 输入框样式 -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- 下拉框样式 -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- 顶部控制面板 -->

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="0" Opacity="0.05"/>
            </Border.Effect>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="TRTC WPF Demo" FontSize="22" FontWeight="Bold" Foreground="#333333"/>
                        <TextBlock x:Name="txtStatus" Text="状态: 未连接" Margin="20,0,0,0" VerticalAlignment="Bottom" Foreground="#666666" FontSize="14"/>
                    </StackPanel>
                </Grid>
                
                <Separator Margin="0,10" Background="#EEEEEE"/>

                <!-- 参数配置行 -->
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="SDK AppId:" VerticalAlignment="Center" Foreground="#666666"/>
                    <ComboBox Grid.Column="1" x:Name="cmbSdkAppId"/>

                    <TextBlock Grid.Column="3" Text="房间号:" VerticalAlignment="Center" Foreground="#666666"/>
                    <TextBox Grid.Column="4" x:Name="txtRoomId" Text="12345"/>

                    <TextBlock Grid.Column="6" Text="用户ID:" VerticalAlignment="Center" Foreground="#666666"/>
                    <TextBox Grid.Column="7" x:Name="txtUserId" Text="user_001"/>

                    <TextBlock Grid.Column="9" Text="应用场景:" VerticalAlignment="Center" Foreground="#666666"/>
                    <ComboBox Grid.Column="10" x:Name="cmbAppScene" SelectionChanged="CmbAppScene_SelectionChanged"/>

                    <TextBlock Grid.Column="12" Text="角色:" VerticalAlignment="Center" Foreground="#666666"/>
                    <ComboBox Grid.Column="13" x:Name="cmbRole"/>
                </Grid>

                <!-- 操作按钮行 -->
                <WrapPanel Margin="0,15,0,0" Orientation="Horizontal">
                    <Button x:Name="btnEnterRoom" Content="进入房间" Style="{StaticResource NormalButtonStyle}" Width="100" Margin="0,0,10,0" Click="BtnEnterRoom_Click"/>
                    <Button x:Name="btnExitRoom" Content="退出房间" Style="{StaticResource DangerButtonStyle}" Width="100" Margin="0,0,10,0" Click="BtnExitRoom_Click" IsEnabled="False"/>
                    
                    <Border Width="1" Height="20" Background="#DDDDDD" Margin="10,0,20,0"/>
                    
                    <Button x:Name="btnSettings" Content="设置" Style="{StaticResource NormalButtonStyle}" Width="100" Margin="0,0,10,0" Click="BtnSettings_Click"/>
                    
                    <Border Width="1" Height="20" Background="#DDDDDD" Margin="10,0,20,0"/>
                    
                    <Button x:Name="btnClearLog" Content="清空日志" Style="{StaticResource NormalButtonStyle}" Background="#999999" Width="80" Click="BtnClearLog_Click"/>
                </WrapPanel>
                <!-- 消息和截图功能测试行 -->
                <Border Margin="0,10,0,0" Padding="10" Background="#F8F9FA" CornerRadius="4">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 自定义消息测试 -->
                            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,0,0">
                                <TextBlock Text="自定义消息测试" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="消息内容:" VerticalAlignment="Center" Foreground="#666666"/>
                                    <TextBox Grid.Column="1" x:Name="txtCustomMessage" Text="Hello TRTC!" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" x:Name="btnSendCustomMsg" Content="发送消息" Style="{StaticResource NormalButtonStyle}" Width="80" Click="BtnSendCustomMsg_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- 分隔线 -->
                            <Border Grid.Column="2" Width="1" Height="40" Background="#DDDDDD" VerticalAlignment="Center"/>

                            <!-- 视频截图测试 -->
                            <StackPanel Grid.Column="4" Orientation="Vertical" Margin="0,0,0,0">
                                <TextBlock Text="视频截图测试" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="用户ID:" VerticalAlignment="Center" Foreground="#666666"/>
                                    <TextBox Grid.Column="1" x:Name="txtSnapshotUserId" VerticalAlignment="Center" Text="user_001"/>

                                    <TextBlock Grid.Column="3" Text="流类型:" VerticalAlignment="Center" Foreground="#666666"/>
                                    <ComboBox Grid.Column="4" x:Name="cmbVideoStreamType" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="6" Text="源类型:" VerticalAlignment="Center" Foreground="#666666"/>
                                    <ComboBox Grid.Column="7" x:Name="cmbSnapshotSourceType" VerticalAlignment="Center"/>

                                    <Button Grid.Column="9" x:Name="btnSnapshot" Content="截图" Style="{StaticResource NormalButtonStyle}" Width="60" Click="BtnSnapshot_Click"/>

                                    <Button Grid.Column="11" x:Name="btnOpenSnapshotFolder" Content="打开文件夹" Style="{StaticResource NormalButtonStyle}" Width="80" Click="BtnOpenSnapshotFolder_Click"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- 视频显示区域 -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 本地视频 -->
            <Border Grid.Column="0" Background="Black" CornerRadius="8" ClipToBounds="True" Margin="0,0,15,0">
                <Grid>
                    <Image x:Name="imgLocalVideo" Stretch="Uniform"/>
                    
                    <!-- 用户名标签 -->
                    <Border Background="#80000000" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="本地视频" Foreground="White" FontSize="12"/>
                    </Border>

                    <!-- 悬浮控制栏 -->
                    <Border Background="#99000000" VerticalAlignment="Bottom" Height="50" CornerRadius="0,0,8,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- 摄像头开关 -->
                            <Button x:Name="btnLocalVideoToggle" Style="{StaticResource IconButtonStyle}" Margin="5" Click="BtnLocalVideoToggle_Click" ToolTip="开启摄像头" IsEnabled="False">
                                <Path x:Name="pathLocalVideoToggle" Data="M17,10.5 L21,6.5 L21,17.5 L17,13.5 L17,18 C17,19.1 16.1,20 15,20 L5,20 C3.9,20 3,19.1 3,18 L3,6 C3,4.9 3.9,4 5,4 L15,4 C16.1,4 17,4.9 17,6 L17,10.5 Z" Stroke="White" StrokeThickness="2" Fill="Transparent" Width="16" Height="16" Stretch="Uniform"/>
                            </Button>


                            <!-- 麦克风开关 -->
                            <Button x:Name="btnLocalAudioToggle" Style="{StaticResource IconButtonStyle}" Margin="5" Click="BtnLocalAudioToggle_Click" ToolTip="开启麦克风" IsEnabled="False">
                                <Path x:Name="pathLocalAudioToggle" Data="M12,14 C13.66,14 15,12.66 15,11 L15,5 C15,3.34 13.66,2 12,2 C10.34,2 9,3.34 9,5 L9,11 C9,12.66 10.34,14 12,14 Z M19,10 L19,11 C19,14.53 16.39,17.44 13,17.93 L13,21 L11,21 L11,17.93 C7.61,17.44 5,14.53 5,11 L5,10 L7,10 L7,11 C7,13.76 9.24,16 12,16 C14.76,16 17,13.76 17,11 L17,10 L19,10 Z" Stroke="White" StrokeThickness="2" Fill="Transparent" Width="16" Height="16" Stretch="Uniform"/>
                            </Button>

                            <!-- 视频推流开关 -->
                            <Button x:Name="btnLocalVideoMute" Style="{StaticResource IconButtonStyle}" Margin="5" Click="BtnLocalVideoMute_Click" ToolTip="屏蔽视频推流" IsEnabled="False">
                                <Path x:Name="pathLocalVideoMute" Data="M2,2 L22,22 M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z" Stroke="White" StrokeThickness="2" Fill="Transparent" Width="16" Height="16" Stretch="Uniform"/>
                            </Button>

                            <Border Width="1" Height="20" Background="#66FFFFFF" Margin="5,0"/>

                            <Button x:Name="btnLocalMirror" Style="{StaticResource IconButtonStyle}" Margin="5" Click="BtnLocalMirror_Click" IsEnabled="False" ToolTip="镜像">
                                <Path Data="M6,4 L18,4 L18,20 L6,20 Z M12,4 L12,20" Stroke="White" StrokeThickness="2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                            <Button x:Name="btnLocalFillMode" Style="{StaticResource IconButtonStyle}" Margin="5" Click="BtnLocalFillMode_Click" IsEnabled="False" ToolTip="填充模式">
                                <Path x:Name="pathLocalFillMode" Data="M4,4 L20,4 L20,20 L4,20 Z M8,8 L16,8 L16,16 L8,16 Z" Stroke="White" StrokeThickness="2" Fill="Transparent" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- 远程视频 -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="0" Opacity="0.05"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="panelRemoteVideo" Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 日志输出 -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="0" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="日志输出" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="txtLog" IsReadOnly="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0"
                             FontFamily="Consolas" FontSize="12" Foreground="#555555"
                             Height="Auto" VerticalContentAlignment="Top" Padding="5"/>
                </ScrollViewer>

            </Grid>
        </Border>
    </Grid>
</Window>


