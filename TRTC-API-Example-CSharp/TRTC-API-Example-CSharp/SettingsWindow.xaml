<Window x:Class="TRTCWPFDemo.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="400" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Device Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Camera:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="cmbCameras" DisplayMemberPath="deviceName" SelectedValuePath="deviceName" SelectionChanged="CmbCameras_SelectionChanged"/>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Mic:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="cmbMics" DisplayMemberPath="deviceName" SelectedValuePath="deviceName" SelectionChanged="CmbMics_SelectionChanged"/>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Speaker:" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="cmbSpeakers" DisplayMemberPath="deviceName" SelectedValuePath="deviceName" SelectionChanged="CmbSpeakers_SelectionChanged"/>
            </Grid>


            <Button Content="Close" Width="100" Height="30" HorizontalAlignment="Center" Margin="0,20,0,0" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>